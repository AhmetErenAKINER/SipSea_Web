<%- include("../partials/header") %>
<section class="card admin-dashboard-layout">
  <h1>Admin Panel</h1>

  <section class="admin-panel-group">
    <h2>Site Bilgileri</h2>
    <div class="admin-info-list">
      <div class="admin-info-row"><span>Toplam Ziyaretçi</span><strong><%= stats.totalVisitors %></strong></div>
      <div class="admin-info-row"><span>Online Kullanıcı</span><strong><%= stats.onlineUsers %></strong></div>
      <div class="admin-info-row"><span>Ürün Sayısı</span><strong><%= stats.totalProducts %></strong></div>
      <div class="admin-info-row"><span>Duyuru Sayısı</span><strong><%= stats.totalAnnouncements %></strong></div>
      <div class="admin-info-row"><span>Galeri Görseli</span><strong><%= stats.totalImages %></strong></div>
      <div class="admin-info-row"><span>Yeni Teklif</span><strong><%= stats.totalQuotes %></strong></div>
    </div>
  </section>

  <section class="admin-panel-group">
    <h2>Admin Kontrolü</h2>
    <div class="admin-link-list">
      <a href="/admin/products">Ürünler</a>
      <a href="/admin/announcements">Duyurular</a>
      <a href="/admin/quotes">Teklif Talepleri</a>
      <a href="/admin/users">Teklif Yetkili E-postalar</a>
      <a href="/admin/gallery">Galeri</a>
      <a href="/admin/settings">Site Metinleri</a>
      <a href="/">Canlı Siteye Git</a>
    </div>
  </section>
</section>
<%- include("../partials/footer") %>
