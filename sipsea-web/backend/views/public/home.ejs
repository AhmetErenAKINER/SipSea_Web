<!DOCTYPE html>
<html class="dark" lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>SipSea Soft | Yeni Nesil Yazılım Çözümleri</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "secondary-container": "#2f486a",
              "primary-fixed": "#d9e4ed",
              "on-error": "#690005",
              "on-background": "#e2e2e2",
              "tertiary-container": "#040404",
              "surface-container": "#1e2020",
              primary: "#bdc8d1",
              "secondary-fixed": "#d4e3ff",
              "outline-variant": "#43474a",
              "on-tertiary-fixed-variant": "#464747",
              "on-primary-fixed": "#131d23",
              background: "#121414",
              tertiary: "#c7c6c6",
              "surface-container-highest": "#333535",
              "on-primary": "#283239",
              "inverse-on-surface": "#2f3131",
              secondary: "#afc8f0",
              "on-surface-variant": "#c4c7ca",
              "error-container": "#93000a",
              "surface-bright": "#37393a",
              "primary-container": "#00050a",
              "on-surface": "#e2e2e2",
              error: "#ffb4ab",
              "tertiary-fixed": "#e4e2e2",
              "surface-container-low": "#1a1c1c",
              "secondary-fixed-dim": "#afc8f0",
              "on-tertiary-container": "#777777",
              "tertiary-fixed-dim": "#c7c6c6",
              "surface-variant": "#333535",
              "surface-container-lowest": "#0c0f0f",
              "surface-dim": "#121414",
              outline: "#8e9195",
              "on-tertiary-fixed": "#1b1c1c",
              "surface-tint": "#bdc8d1",
              "on-primary-fixed-variant": "#3e484f",
              "on-secondary-container": "#9eb7de",
              "on-secondary-fixed": "#001c3a",
              "inverse-surface": "#e2e2e2",
              "on-error-container": "#ffdad6",
              "on-secondary": "#163152",
              surface: "#121414",
              "surface-container-high": "#282a2b",
              "on-secondary-fixed-variant": "#2f486a",
              "inverse-primary": "#556067",
              "primary-fixed-dim": "#bdc8d1",
              "on-tertiary": "#303031",
              "on-primary-container": "#6e7880"
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem"
            },
            spacing: {
              unit: "4px",
              gutter: "24px",
              "bento-gap": "16px",
              margin: "48px"
            },
            fontFamily: {
              "headline-lg": ["Inter"],
              "body-lg": ["Inter"],
              "label-caps": ["Inter"],
              "headline-xl": ["Inter"],
              "body-md": ["Inter"],
              "headline-md": ["Inter"]
            },
            fontSize: {
              "headline-lg": [
                "48px",
                {
                  lineHeight: "1.2",
                  letterSpacing: "-0.02em",
                  fontWeight: "600"
                }
              ],
              "body-lg": [
                "18px",
                {
                  lineHeight: "1.6",
                  letterSpacing: "0em",
                  fontWeight: "400"
                }
              ],
              "label-caps": [
                "12px",
                {
                  lineHeight: "1.0",
                  letterSpacing: "0.1em",
                  fontWeight: "600"
                }
              ],
              "headline-xl": [
                "80px",
                {
                  lineHeight: "1.1",
                  letterSpacing: "-0.04em",
                  fontWeight: "700"
                }
              ],
              "body-md": [
                "16px",
                {
                  lineHeight: "1.5",
                  letterSpacing: "0em",
                  fontWeight: "400"
                }
              ],
              "headline-md": [
                "32px",
                {
                  lineHeight: "1.3",
                  letterSpacing: "-0.01em",
                  fontWeight: "600"
                }
              ]
            }
          }
        }
      };
    </script>
    <link rel="stylesheet" href="/static/styles.css" />
    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        background-color: #121414;
        color: #e2e2e2;
        overflow-x: hidden;
        transition: background-color 1.8s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .surface-wave-layer {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(
            to right,
            rgba(255, 255, 255, 0.06) 0,
            rgba(255, 255, 255, 0.06) 1px,
            transparent 1px,
            transparent 25%
          ),
          radial-gradient(circle at 20% 10%, rgba(189, 200, 209, 0.12) 0%, transparent 45%),
          radial-gradient(circle at 80% 20%, rgba(130, 150, 175, 0.12) 0%, transparent 40%),
          linear-gradient(180deg, rgba(18, 28, 36, 0.62) 0%, rgba(10, 18, 24, 0.86) 100%);
        background-size: 320px 100%, auto, auto, auto;
        background-position: center, center, center, center;
        background-repeat: repeat, no-repeat, no-repeat, no-repeat;
        opacity: 0.34;
        filter: saturate(0.8) brightness(0.72) contrast(1.08);
        transition: opacity 1.2s ease, transform 1.2s ease;
      }
      .depth-darken-layer {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: linear-gradient(
          to bottom,
          rgba(8, 14, 22, 0.08) 0%,
          rgba(3, 8, 14, 0.28) 40%,
          rgba(1, 3, 7, 0.72) 75%,
          rgba(0, 0, 0, 0.92) 100%
        );
        opacity: 0.35;
        transition: opacity 1.2s ease;
      }
      
      .glass-panel {
        background: rgba(48, 50, 52, 0.82);
        backdrop-filter: blur(28px) saturate(1.12);
        -webkit-backdrop-filter: blur(28px) saturate(1.12);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 10px !important;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.12) inset,
          0 -2px 12px rgba(0, 0, 0, 0.35) inset,
          0 10px 28px rgba(0, 0, 0, 0.45),
          0 22px 56px rgba(0, 0, 0, 0.38),
          0 0 0 1px rgba(0, 0, 0, 0.35);
      }
      .frosted-water {
        background: linear-gradient(
          148deg,
          rgba(58, 61, 64, 0.92) 0%,
          rgba(38, 40, 42, 0.94) 45%,
          rgba(24, 26, 26, 0.96) 100%
        );
        border: 1px solid rgba(189, 200, 209, 0.22);
        border-radius: 10px !important;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.08) inset,
          0 8px 24px rgba(0, 0, 0, 0.42),
          0 18px 44px rgba(0, 0, 0, 0.32),
          0 0 0 1px rgba(0, 0, 0, 0.28);
      }
      .frosted-water.glass-panel {
        background: linear-gradient(
          152deg,
          rgba(62, 65, 68, 0.93) 0%,
          rgba(42, 44, 46, 0.94) 50%,
          rgba(26, 28, 28, 0.97) 100%
        );
        border-color: rgba(189, 200, 209, 0.24);
      }
      
      .sipsea-quote-shell.glass-panel {
        background: rgba(44, 46, 48, 0.88);
        border-radius: 12px !important;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.14) inset,
          0 -3px 16px rgba(0, 0, 0, 0.4) inset,
          0 14px 36px rgba(0, 0, 0, 0.5),
          0 28px 64px rgba(0, 0, 0, 0.42),
          0 0 0 1px rgba(0, 0, 0, 0.38);
      }
      
      .sipsea-contact-strip article.frosted-water {
        background: linear-gradient(
          160deg,
          rgba(52, 54, 56, 0.95) 0%,
          rgba(34, 36, 36, 0.98) 100%
        );
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px !important;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.07) inset,
          0 6px 16px rgba(0, 0, 0, 0.38),
          0 14px 32px rgba(0, 0, 0, 0.28);
      }
      
      .sipsea-quote-shell .quote-field,
      .sipsea-quote-shell textarea.quote-field,
      .sipsea-quote-shell select.quote-select {
        border-radius: 8px !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        background-color: rgba(28, 30, 32, 0.95) !important;
      }
      .sipsea-quote-shell .quote-field:-webkit-autofill,
      .sipsea-quote-shell .quote-field:-webkit-autofill:hover,
      .sipsea-quote-shell .quote-field:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px rgba(28, 30, 32, 0.95) inset !important;
      }
      
      #founders .sipsea-founder-card.frosted-water.glass-panel {
        width: 100%;
      }
      
      .sipsea-founder-card .sipsea-founder-photo {
        border-radius: 8px !important;
        background: linear-gradient(
          180deg,
          rgba(26, 28, 30, 0.98) 0%,
          rgba(14, 16, 16, 0.99) 100%
        ) !important;
        border: 1px solid rgba(0, 0, 0, 0.45) !important;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.06) inset,
          inset 0 6px 18px rgba(0, 0, 0, 0.35);
      }
      .sipsea-sea-legend {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 0.75rem 1rem;
      }
      .sipsea-sea-letter-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 3.25rem;
        height: 3.25rem;
        padding: 0 0.75rem;
        border-radius: 14px;
        font-size: 1.65rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        color: #1a2228;
        background: linear-gradient(160deg, #e8eef3 0%, #bdc8d1 45%, #8fa8b8 100%);
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.2) inset,
          0 8px 28px rgba(189, 200, 209, 0.28);
      }
      .sipsea-sea-caption {
        width: 100%;
        text-align: center;
        font-size: 0.9rem;
        color: #9ca3af;
        margin-top: 0.35rem;
      }
      .sipsea-sea-caption strong {
        color: #bdc8d1;
        font-weight: 700;
        letter-spacing: 0.12em;
      }
      .sipsea-founder-name {
        font-size: 1.5rem;
        line-height: 1.2;
        text-align: center;
      }
      .sipsea-founder-letter {
        display: inline-block;
        font-size: 1.55em;
        font-weight: 800;
        color: #bdc8d1;
        margin-right: 0.02em;
        text-shadow: 0 0 28px rgba(189, 200, 209, 0.55);
        vertical-align: baseline;
      }
      .diving-glow {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        pointer-events: none;
        z-index: 2;
        background: radial-gradient(
          circle at 50% 0%,
          rgba(189, 200, 209, 0.12) 0%,
          transparent 70%
        );
        mix-blend-mode: soft-light;
      }
      .seigaiha-pattern {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        pointer-events: none;
        z-index: 0;
        opacity: 0.22;
        background-image: url("/static/images/background/sea-pattern-wave.png");
        background-size: 360px;
        background-repeat: repeat;
        background-position: center;
        mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
        -webkit-mask-image: linear-gradient(
          to bottom,
          black 0%,
          transparent 100%
        );
      }
      .hero-wave-graphic {
        position: absolute;
        top: 10%;
        right: -5%;
        width: 70%;
        max-width: 1200px;
        opacity: 0;
        z-index: 0;
        filter: contrast(1.1) brightness(1.2) grayscale(0.5);
        pointer-events: none;
        mask-image: radial-gradient(
          circle at center,
          black 0%,
          transparent 80%
        );
        -webkit-mask-image: radial-gradient(
          circle at center,
          black 0%,
          transparent 80%
        );
      }
      .atmospheric-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(
          circle at 50% -20%,
          rgba(189, 200, 209, 0.08) 0%,
          transparent 80%
        );
        pointer-events: none;
        z-index: 1;
      }
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
      }
      select.quote-select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-color: #121414 !important;
        color: #e2e2e2 !important;
        color-scheme: dark;
      }
      select.quote-select option {
        background-color: #121414 !important;
        color: #e2e2e2 !important;
      }
      input.quote-field,
      textarea.quote-field,
      select.quote-select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-color: #121414 !important;
        color: #e2e2e2 !important;
        color-scheme: dark;
        padding-left: 1rem !important;
      }
      .quote-field::placeholder {
        color: #8e9195;
      }
      .quote-field:-webkit-autofill,
      .quote-field:-webkit-autofill:hover,
      .quote-field:-webkit-autofill:focus {
        -webkit-text-fill-color: #e2e2e2;
        -webkit-box-shadow: 0 0 0 1000px #121414 inset;
        transition: background-color 9999s ease-out 0s;
      }
      
      .home-top-navbar {
        overflow: visible !important;
      }
      .home-nav-links {
        overflow: visible;
      }
      @media (min-width: 768px) {
        .home-top-navbar .nav-products-dropdown:hover .nav-products-menu-desktop {
          display: block !important;
        }
      }
      @media (max-width: 767px) {
        .nav-products-menu-desktop {
          display: none !important;
        }
      }
    </style>
  </head>
  <body class="font-body-md antialiased" style="background-color: #121414">
    <div class="surface-wave-layer" id="surfaceWaveLayer"></div>
    <div class="depth-darken-layer" id="depthDarkenLayer"></div>
    <div class="seigaiha-pattern" id="seigaiha"></div>
    <div class="diving-glow" id="divingGlow"></div>
    <div class="atmospheric-overlay" id="atmos" style="opacity: 1"></div>
    <%- include("../partials/public-navbar", { navMode: "landing" }) %>

    <div class="depth-wrapper">
      
      <section
        id="top"
        class="relative min-h-[1024px] flex flex-col justify-center px-8 pt-32 pb-16 overflow-hidden"
      >
        <div class="hero-wave-graphic" id="heroWave"></div>
        <div class="max-w-7xl mx-auto w-full relative z-10">
          <div class="max-w-4xl">
            <span
              class="font-label-caps text-primary uppercase tracking-[0.2em] mb-6 block"
              ><%= settings.hero_badge_text || "Kuruluş 2026" %></span
            >
            <h1
              class="font-headline-xl text-on-surface mb-8 tracking-tight"
            >
              <%= settings.hero_title_text || "Yeni Nesil Yazılım Mükemmelliği." %>
            </h1>
            <p
              class="font-body-lg text-on-surface-variant max-w-2xl leading-relaxed"
            >
              <%= settings.hero_description_text || "Zekâ ile ölçeklenebilirliği dengeleyen dijital temeller tasarlıyoruz. Amacımız, karmaşık problemleri uzun ömürlü kod ile görünmez ve akıcı deneyimlere dönüştürmek." %>
            </p>
            <div class="mt-12 flex gap-6">
              <a
                href="/urunler"
                class="bg-primary text-on-primary px-8 py-4 rounded-full font-label-caps hover:brightness-110 transition-all shadow-lg shadow-primary/10 text-sm"
                >Ürünleri İncele</a
              >
              <a
                href="#contact"
                class="border border-outline-variant text-on-surface px-8 py-4 rounded-full font-label-caps hover:bg-surface-variant/20 transition-all backdrop-blur-sm text-sm"
                >Teklif Talep Et</a
              >
            </div>
          </div>
        </div>
      </section>

      
      <section
        class="py-32 px-8 max-w-7xl mx-auto relative z-10 transition-all duration-1000"
        id="products"
      >
        <div class="mb-16">
          <h2
            class="font-headline-lg text-on-surface mb-4 tracking-tight"
          >
            <%= settings.products_section_title || "Ürün Vitrini" %>
          </h2>
          <p class="font-body-md text-on-surface-variant">
            <%= settings.products_section_description || "Modern verimliliğin yazılım mimarisi." %>
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-12 gap-bento-gap auto-rows-[300px]"
        >
          <% const primaryProduct = products && products.length ? products[0] : null; %>
          <% const secondaryProduct = products && products.length > 1 ? products[1] : null; %>
          <% const tertiaryProduct = products && products.length > 2 ? products[2] : null; %>
          
          <div<% if (primaryProduct) { %> id="<%= primaryProduct.slug %>"<% } %>
            class="md:col-span-8 md:row-span-2 frosted-water glass-panel p-10 group relative overflow-hidden scroll-mt-24"
          >
            <% if (primaryProduct && primaryProduct.cover_image_path) { %>
              <img
                src="<%= primaryProduct.cover_image_path %>"
                alt="<%= primaryProduct.title %>"
                class="absolute inset-0 w-full h-full object-cover opacity-25"
              />
            <% } %>
            <div class="relative z-10 h-full flex flex-col">
              <span class="font-label-caps text-primary mb-4 block"
                ><%= (primaryProduct && primaryProduct.tech_stack) ? primaryProduct.tech_stack : "MOBİL PLATFORM" %></span
              >
              <h3
                class="font-headline-md text-on-surface mb-4 tracking-tight"
              >
                <%= primaryProduct ? primaryProduct.title : "DealMate" %>
              </h3>
              <p
                class="font-body-md text-on-surface-variant max-w-md"
              >
                <%= (primaryProduct && primaryProduct.summary) ? primaryProduct.summary : "Yuksek hacimli islemler ve hizli yayginlastirma icin tasarlanmis gelismis bir pazar yeri motoru." %>
              </p>
              <% if (primaryProduct) { %>
                <a href="/urunler/<%= primaryProduct.slug %>" class="mt-4 inline-block font-label-caps text-primary text-sm hover:underline">Detay →</a>
              <% } %>
            </div>
          </div>

          
          <div<% if (secondaryProduct) { %> id="<%= secondaryProduct.slug %>"<% } %>
            class="md:col-span-4 md:row-span-1 frosted-water glass-panel p-8 flex flex-col justify-between scroll-mt-24"
          >
            <div>
              <span class="font-label-caps text-primary mb-2 block"
                ><%= (secondaryProduct && secondaryProduct.tech_stack) ? secondaryProduct.tech_stack : "WEB ÇOZUMLERI" %></span
              >
              <h3
                class="font-headline-md text-on-surface tracking-tight"
              >
                <%= secondaryProduct ? secondaryProduct.title : "Ozel Web Siteleri" %>
              </h3>
            </div>
            <p class="font-body-md text-on-surface-variant">
              <%= (secondaryProduct && secondaryProduct.summary) ? secondaryProduct.summary : "WordPress tabanli cozumlerden tamamen kodlanmis arayuzlere kadar olceklenebilir yapilar." %>
            </p>
            <% if (secondaryProduct) { %>
              <a href="/urunler/<%= secondaryProduct.slug %>" class="mt-3 inline-block font-label-caps text-primary text-sm hover:underline">Detay →</a>
            <% } %>
          </div>

          <div<% if (tertiaryProduct) { %> id="<%= tertiaryProduct.slug %>"<% } %>
            class="md:col-span-4 md:row-span-1 frosted-water glass-panel p-8 overflow-hidden scroll-mt-24 <%= tertiaryProduct && tertiaryProduct.cover_image_path ? 'relative' : '' %>"
          >
            <% if (tertiaryProduct && tertiaryProduct.cover_image_path) { %>
              <img
                src="<%= tertiaryProduct.cover_image_path %>"
                alt="<%= tertiaryProduct.title %>"
                class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none"
              />
            <% } %>
            <div
              class="relative z-10 h-full flex flex-col justify-center items-center text-center px-2"
            >
              <% if (tertiaryProduct) { %>
                <span class="font-label-caps text-primary mb-3 block tracking-wide uppercase"
                  ><%= tertiaryProduct.tech_stack || "Platform" %></span
                >
                <h4
                  class="font-headline-md text-on-surface text-xl tracking-tight"
                >
                  <%= tertiaryProduct.title %>
                </h4>
                <% if (tertiaryProduct.summary) { %>
                  <p class="font-body-md text-on-surface-variant text-sm mt-3 max-w-xs">
                    <%= tertiaryProduct.summary %>
                  </p>
                <% } %>
                <a href="/urunler/<%= tertiaryProduct.slug %>" class="mt-3 inline-block font-label-caps text-primary text-sm hover:underline">Detay →</a>
              <% } else { %>
                <span
                  class="material-symbols-outlined text-4xl text-primary mb-4"
                  >insights</span
                >
                <h4
                  class="font-headline-md text-on-surface text-xl tracking-tight"
                >
                  Core Analytics
                </h4>
                <p class="font-body-md text-on-surface-variant text-sm mt-2">
                  Geliştirdiğimiz her platform için yerleşik analitik ve içgörü.
                </p>
              <% } %>
            </div>
          </div>
        </div>
        <p class="mt-8">
          <a href="/urunler" class="font-label-caps text-primary hover:underline">Tüm ürünler →</a>
        </p>
      </section>

      
      <section class="py-24 px-8 max-w-7xl mx-auto relative z-10" id="news">
        <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 class="font-headline-lg text-on-surface mb-2 tracking-tight">Duyurular ve Haberler</h2>
            <p class="font-body-md text-on-surface-variant">Son gelişmeler ve duyurular.</p>
          </div>
          <a href="/duyurular" class="font-label-caps text-primary hover:underline">Tümünü gör →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% (announcements || []).forEach(item => { %>
            <a
              href="/duyurular/<%= item.slug %>"
              class="frosted-water glass-panel p-6 block no-underline hover:brightness-105 transition-all"
            >
              <% if (item.category_name) { %>
                <span class="font-label-caps text-primary text-xs block mb-2"><%= item.category_name %></span>
              <% } %>
              <h3 class="font-headline-md text-on-surface mb-2 tracking-tight"><%= item.title %></h3>
              <p class="font-body-md text-on-surface-variant text-sm line-clamp-3"><%= item.summary || "" %></p>
            </a>
          <% }) %>
          <% if (!announcements || !announcements.length) { %>
            <p class="text-on-surface-variant col-span-full">Henüz yayınlanmış duyuru yok.</p>
          <% } %>
        </div>
      </section>

      
      <section
        class="py-32 relative z-10 transition-all duration-1000"
        id="founders"
      >
        <div class="px-8 max-w-7xl mx-auto">
          <div class="mb-16 text-center">
            <h2
              class="font-headline-xl text-on-surface mb-6 tracking-tight"
            >
              <%= settings.founders_section_title || "Vizyonumuz." %>
            </h2>
            <p
              class="font-headline-md text-primary max-w-3xl mx-auto opacity-80 leading-tight"
            >
              "Yazılımın taş kadar sağlam, düşünce kadar akışkan olması
              gerektiğine inanıyoruz."
            </p>
          </div>

          <div class="sipsea-sea-legend mb-12">
            <% founders.forEach((founder) => { %>
              <% const seaLetter = (founder.full_name || "").trim().charAt(0).toUpperCase(); %>
              <span class="sipsea-sea-letter-pill"><%= seaLetter %></span>
            <% }) %>
            <p class="sipsea-sea-caption">
              Sip<strong>SEA</strong> — <%= founders.map((f) => f.full_name).join(" · ") %>
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
            <% founders.forEach(founder => { %>
              <% const founderName = (founder.full_name || "").trim(); %>
              <% const founderFirst = founderName.charAt(0); %>
              <% const founderRest = founderName.slice(1); %>
              <article class="sipsea-founder-card frosted-water glass-panel flex flex-col items-center p-6 md:p-8 w-full">
                <div
                  class="sipsea-founder-photo w-full aspect-[3/4] mb-6 overflow-hidden flex items-center justify-center text-on-surface-variant text-sm"
                >
                  <% if (founder.photo_path) { %>
                    <img src="<%= founder.photo_path %>" alt="<%= founder.full_name %>" class="w-full h-full object-cover" />
                  <% } else { %>
                    Co-founder photo placeholder
                  <% } %>
                </div>
                <h4 class="sipsea-founder-name font-headline-md text-on-surface tracking-tight">
                  <span class="sipsea-founder-letter"><%= founderFirst %></span><%= founderRest %>
                </h4>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      
      <section
        class="py-32 px-8 bg-surface-container-lowest relative z-20"
        id="contact"
      >
        <div class="max-w-6xl mx-auto space-y-10">
          <div
            id="quote"
            class="sipsea-quote-shell glass-panel p-16 max-w-3xl mx-auto"
          >
          <div class="mb-12">
            <h2
              class="font-headline-md text-on-surface mb-4 tracking-tight"
            >
              <%= settings.quote_section_title || "Projeni Başlat." %>
            </h2>
            <p class="font-body-md text-on-surface-variant">
              <%= settings.quote_section_description || "Hedefini anlat, mimariyi ve altyapıyı biz tasarlayalım." %>
            </p>
            <p class="mt-3 text-sm text-on-surface-variant/90">
              Teklif göndermek için yalnızca admin tarafından sisteme eklenmiş e-posta adresleri kullanılabilir.
            </p>
          </div>
          <% if (quoteMessage) { %>
            <p class="mb-6 rounded-lg border px-4 py-3 text-sm <%= quoteMessageType === 'error' ? 'border-red-400/50 bg-red-500/10 text-red-100' : 'border-primary/40 bg-primary/10 text-on-surface' %>">
              <%= quoteMessage %>
            </p>
          <% } %>
          <form class="space-y-8" method="post" action="/teklif">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div>
              <label class="font-label-caps text-primary block mb-2"
                >AD SOYAD</label
              >
              <input
                class="quote-field w-full border-b border-outline-variant focus:border-primary py-3 pl-4 pr-0 outline-none transition-all"
                placeholder="Ahmet Yılmaz"
                name="full_name"
                type="text"
                required
              />
            </div>
            <div>
              <label class="font-label-caps text-primary block mb-2"
                >E-POSTA ADRESİ</label
              >
              <input
                class="quote-field w-full border-b border-outline-variant focus:border-primary py-3 pl-4 pr-0 outline-none transition-all"
                placeholder="ahmet@example.com"
                name="email"
                type="email"
                required
              />
            </div>
            <div>
              <label class="font-label-caps text-primary block mb-2"
                >PROJE TİPİ</label
              >
              <select
                class="quote-select w-full border-b border-outline-variant focus:border-primary py-3 pl-4 pr-0 outline-none transition-all"
                name="project_type"
              >
                <option value="">Seçiniz</option>
                <option value="Mobil Uygulama">Mobil Uygulama</option>
                <option value="Kurumsal Web Sitesi">Kurumsal Web Sitesi</option>
                <option value="E-Ticaret">E-Ticaret</option>
                <option value="Özel Yazılım">Özel Yazılım</option>
                <option value="Diğer">Diğer</option>
              </select>
            </div>
            <div>
              <label class="font-label-caps text-primary block mb-2"
                >BÜTÇE ARALIĞI</label
              >
              <select
                class="quote-select w-full border-b border-outline-variant focus:border-primary py-3 pl-4 pr-0 outline-none transition-all"
                name="budget_range"
              >
                <option value="">Seçiniz</option>
                <option value="0 - 25.000 TL">0 - 25.000 TL</option>
                <option value="25.000 - 75.000 TL">25.000 - 75.000 TL</option>
                <option value="75.000 - 150.000 TL">75.000 - 150.000 TL</option>
                <option value="150.000 TL+">150.000 TL+</option>
              </select>
            </div>
            <div>
              <label class="font-label-caps text-primary block mb-2"
                >KISA AÇIKLAMA</label
              >
              <textarea
                class="quote-field w-full border-b border-outline-variant focus:border-primary py-3 pl-4 pr-0 outline-none transition-all resize-none"
                placeholder="Çözmemizi istediğiniz problemi kısaca anlatın..."
                name="message"
                rows="4"
                required
              ></textarea>
            </div>
            <button
              class="w-full bg-primary text-on-primary py-4 rounded-full font-label-caps hover:brightness-110 transition-all uppercase tracking-widest mt-8"
              type="submit"
            >
              Talep Gönder
            </button>
          </form>
          </div>

          <section id="contact-info" class="glass-panel sipsea-contact-strip p-8">
            <h3 class="font-headline-md text-on-surface mb-6 tracking-tight">
              İletişim
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
              <article class="frosted-water p-5">
                <p class="font-label-caps text-primary mb-2">E-Posta</p>
                <p class="font-body-md text-on-surface"><%= settings.contact_email || "example@gmail.com" %></p>
              </article>
              <article class="frosted-water p-5">
                <p class="font-label-caps text-primary mb-2">Telefon</p>
                <p class="font-body-md text-on-surface"><%= settings.contact_phone || "+90 555 000 00 00" %></p>
              </article>
              <article class="frosted-water p-5">
                <p class="font-label-caps text-primary mb-2">Adres</p>
                <p class="font-body-md text-on-surface"><%= settings.contact_address || "Istanbul, Turkiye" %></p>
              </article>
            </div>
          </section>
        </div>
      </section>
    </div>

    
    <footer
      class="bg-surface-container-lowest w-full py-12 border-t border-white/5 relative z-10"
    >
      <div
        class="max-w-7xl mx-auto px-8 flex flex-col items-center gap-8"
      >
        <div
          class="text-lg font-semibold text-on-surface font-inter tracking-tight"
        >
          SipSea Soft
        </div>
        <div class="text-on-surface-variant font-inter text-sm">
          <%= settings.footer_copyright_text || "© 2026 SipSea Soft. Tüm hakları saklıdır." %>
        </div>
      </div>
    </footer>

    <script src="/static/js/home-parallax.js?v=1"></script>
    <script src="/static/js/online-tab-ping.js?v=1"></script>
    <script src="/static/js/admin-return-button.js?v=1"></script>
  </body>
</html>
