<%- include("../partials/header") %>
<div class="login-wave-bg" aria-hidden="true"></div>
<section class="login-screen">
  <section class="card narrow login-card">
    <h1>Admin Girişi</h1>
    <% if (message) { %><p class="alert"><%= message %></p><% } %>
    <form method="post" action="/auth/login<%= returnUrl ? '?url=' + encodeURIComponent(returnUrl) : '' %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>E-posta</label>
      <input type="email" name="email" required />
      <label>Şifre</label>
      <div class="password-field">
        <input id="passwordInput" type="password" name="password" required />
        <button id="togglePasswordBtn" class="password-toggle-btn" type="button" aria-label="Şifreyi göster">
          <span class="password-toggle-icon eye-open" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
              <circle cx="12" cy="12" r="2.8"></circle>
            </svg>
          </span>
          <span class="password-toggle-icon eye-closed" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
              <circle cx="12" cy="12" r="2.8"></circle>
              <path d="M4 20L20 4"></path>
            </svg>
          </span>
        </button>
      </div>
      <button type="submit">Giriş Yap</button>
    </form>
  </section>
</section>
<script>
  (function () {
    const input = document.getElementById("passwordInput");
    const btn = document.getElementById("togglePasswordBtn");
    if (!input || !btn) return;

    btn.addEventListener("click", () => {
      const visible = input.type === "text";
      input.type = visible ? "password" : "text";
      btn.setAttribute("aria-label", visible ? "Şifreyi göster" : "Şifreyi gizle");
      btn.classList.toggle("is-visible", !visible);
    });
  })();
</script>
<%- include("../partials/footer") %>
