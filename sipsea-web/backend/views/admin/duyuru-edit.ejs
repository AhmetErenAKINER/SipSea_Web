<%- include("../partials/header") %>
<section class="card">
  <div class="admin-page-toolbar">
    <a class="admin-back-link" href="/admin/announcements">← Geri</a>
  </div>
  <h1>Duyuru Düzenle</h1>
  <form method="post" action="/admin/announcements/update">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="announcement_id" value="<%= announcement.id %>" />
    <label>Başlık</label>
    <input name="title" value="<%= announcement.title %>" required />

    <label>Özet</label>
    <textarea name="summary" rows="2"><%= announcement.summary || "" %></textarea>

    <label>İçerik</label>
    <textarea name="content" rows="8" required><%= announcement.content %></textarea>

    <label>Kategori</label>
    <select name="category_id">
      <option value="">Seçiniz</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.id %>" <%= announcement.category_id === c.id ? "selected" : "" %>><%= c.name %></option>
      <% }) %>
    </select>

    <p>Slug: <code><%= announcement.slug %></code></p>

    <label class="form-checkbox-inline">
      <input type="checkbox" name="is_published" <%= announcement.is_published ? "checked" : "" %> />
      <span>Yayınlansın</span>
    </label>
    <button type="submit">Güncelle</button>
  </form>
</section>
<%- include("../partials/footer") %>
