<%- include("../partials/header") %>
<section class="card">
  <div class="admin-page-toolbar">
    <a class="admin-back-link" href="/admin/products">← Geri</a>
  </div>
  <h1>Ürün Düzenle</h1>
  <form method="post" action="/admin/products/update">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="product_id" value="<%= product.id %>" />
    <label>Başlık</label>
    <input name="title" required value="<%= product.title %>" />

    <label>Özet</label>
    <textarea name="summary" rows="2"><%= product.summary || "" %></textarea>

    <label>Detaylı İçerik</label>
    <textarea name="content" rows="8" required><%= product.content %></textarea>

    <label>Teknoloji Yığını</label>
    <input name="tech_stack" placeholder="React Native, Node.js, MySQL" value="<%= product.tech_stack || "" %>" />

    <label>Kapak Görseli Yolu (opsiyonel)</label>
    <input name="cover_image_path" placeholder="/uploads/gallery/ornek.png" value="<%= product.cover_image_path || "" %>" />

    <p class="muted-lead">Mevcut slug: <code><%= product.slug %></code> (başlık değişince otomatik güncellenir.)</p>

    <label class="form-checkbox-inline"><input type="checkbox" name="is_published" <%= Number(product.is_published) === 1 ? "checked" : "" %> /><span>Yayınlansın</span></label>
    <button type="submit">Güncelle</button>
  </form>
</section>
<%- include("../partials/footer") %>
